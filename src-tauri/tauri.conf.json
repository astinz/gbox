{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gbox",
  "version": "0.1.0",
  "identifier": "xyz.mcxross.gbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "gBox — Evidence & Control",
        "width": 1320,
        "height": 840,
        "minWidth": 1040,
        "minHeight": 700
      },
      {
        "label": "approval",
        "title": "gBox Approval Required",
        "width": 560,
        "height": 720,
        "minWidth": 500,
        "minHeight": 620,
        "visible": false,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
